---
interface Props {
  pageTitle: string;
}

const { pageTitle } = Astro.props as Props;
---

<meta charset="utf-8" />
<link rel="icon" href="/favicon.ico" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />
<title>{pageTitle} | GC Design System</title>
<meta name="og:title" content={`${pageTitle} | GC Design System`} />

<!-- GC Design System CSS Shortcuts -->
<link rel="stylesheet" href="/assets/gcds/gcds-css-shortcuts.min.css" />

<!-- GC Design System -->
<link rel="stylesheet" href="/assets/gcds/gcds.css" />
<script type="module" src="/assets/gcds/gcds.esm.js"></script>
