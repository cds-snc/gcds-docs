---
import { supportedLocales } from '../i18n/config';
import Breadcrumbs from './Breadcrumbs.astro';
import type { Locale, RouteKey } from '../utils/docs-static-paths';
import { getFullRoutePath } from '../utils/breadcrumbs';

interface Props {
  currentLocale: Locale;
  routeKey: RouteKey;
}

const { currentLocale, routeKey } = Astro.props as Props;
const otherLocale = supportedLocales.find(loc => loc !== currentLocale) || currentLocale;
const href = getFullRoutePath(routeKey, otherLocale as Locale);
---

<gcds-header
  lang={currentLocale}
  lang-href={href}
  skip-to-href="#main-content"
>
  <Breadcrumbs currentLocale={currentLocale} routeKey={routeKey} />
  <gcds-search slot="search"></gcds-search>
</gcds-header>