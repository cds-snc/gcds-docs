---
---

<div class="preview-container">
  <div class="code-preview">
    <div class="demo-container">
      <slot />
    </div>

    <div class="button-group">
      <gcds-button class="toggle-btn" button-role="secondary" size="small">
        View Code
      </gcds-button>
      <gcds-button class="copy-btn" button-role="secondary" size="small">
        Copy Code
      </gcds-button>
      <span class="copy-status"></span>
    </div>
  </div>

  <pre class="code-block hidden">
    <code class="code-content"></code>
  </pre>
</div>

<script>
  import { initCodePreviews } from "../scripts/code-preview.js";
  document.addEventListener("DOMContentLoaded", initCodePreviews);
</script>