---

<gcds-side-nav label={navConfig.sideNavLabel}>
    {navConfig.links.map((link) => (
            <gcds-nav-link href={link.href}>
                {link.icon && <img src={link.icon.src} alt={link.icon.alt} />}
                {link.text}
            </gcds-nav-link>
    ))}

    {navConfig.groups.map((group) => (
            <gcds-nav-group open-trigger={group.trigger} menu-label={group.menuLabel}>
                {group.links.map((link) => (
                        <gcds-nav-link href={link.href}>{link.text}</gcds-nav-link>
                ))}
            </gcds-nav-group>
    ))}
</gcds-side-nav>

<style>
    gcds-side-nav {
        z-index: 1;
        position: fixed;
        top: calc(6.9375rem + 3px);
        left: 0;
        bottom: 0;
        width: 20rem;
        overflow-y: scroll;
        background-color: var(--gcds-bg-white);
        border-inline-end: var(--gcds-border-width-sm) solid var(--gcds-header-brand-border-color);
        padding: var(--gcds-spacing-300);
    }

    gcds-side-nav img {
        width: 1.25rem;
        height: 1.25rem;
        margin-inline-end: var(--gcds-spacing-200);
    }
</style>
