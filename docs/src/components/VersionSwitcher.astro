---
import {
  buildLatestPath,
  buildVersionPath,
  getPageDefinition,
  type Locale,
  type VersionedSectionKey,
  versionManifest,
} from "../utils/version-manifest";

interface Props {
  locale: Locale;
  section: VersionedSectionKey;
  currentVersion: string;
  pageKey: string;
}

const { locale, section, currentVersion, pageKey } = Astro.props as Props;
const sectionMeta = versionManifest[section];
const page = getPageDefinition(section, pageKey);

if (!page) {
  throw new Error(`Unknown versioned page key '${pageKey}' for section '${section}'`);
}

const versionOptions = sectionMeta.versions.map(version => {
  const snapshot = page.snapshots[version]?.[locale];
  const sectionLanding = getPageDefinition(section, "section");
  const fallback = sectionLanding
    ? buildVersionPath(locale, section, version, sectionLanding.slugs[locale])
    : buildLatestPath(locale, section, []);

  const href = snapshot
    ? version === sectionMeta.latest
      ? buildLatestPath(locale, section, page.slugs[locale])
      : buildVersionPath(locale, section, version, page.slugs[locale])
    : `${fallback}?fallback=1&missing=${encodeURIComponent(page.labels[locale])}&from=${encodeURIComponent(currentVersion)}`;

  return {
    version,
    href,
    missing: !snapshot,
  };
});
---
<gcds-select
  select-id="version-switcher"
  name="version-switcher"
  label="Version"
  data-current={currentVersion}
>
  {versionOptions.map(option => (
    <option
      value={option.version}
      data-href={option.href}
      selected={option.version === currentVersion}
    >
      {option.version}{option.missing ? " (fallback)" : ""}
    </option>
  ))}
</gcds-select>


<script is:inline define:vars={{ versionOptions }}>
    document.addEventListener('gcdsChange', (e) => {
        if (e.target.selectId === 'version-switcher') {
            const selectedVersion = e.target.value;
            const versionURL = versionOptions.find((item) => item.version === selectedVersion)?.href ?? null;
            console.log(versionURL);
            if (versionURL) {
                window.location.assign(versionURL);
            }
        }
    });
</script>