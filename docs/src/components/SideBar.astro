---
import { getNavData, type Locale, type RouteKey } from "../utils/docs-static-paths";

interface Props {
  currentLocale: Locale;
  routeKey?: RouteKey;
}

const { currentLocale, routeKey = "home" } = Astro.props as Props;
const { primaryLinks, externalLinks, sections } = getNavData(currentLocale);
---

<gcds-side-nav
  label="GC Design System"
  class="side-nav"
>
  {primaryLinks.map(link => (
    <gcds-nav-link href={link.href} aria-current={link.routeKey === routeKey ? "page" : undefined}>
      {link.label}
    </gcds-nav-link>
  ))}

  {externalLinks.map(link => (
    <gcds-nav-link href={link.href}>
      {link.icon && <img src={link.icon.src} alt={link.icon.alt} />}
      {link.label}
    </gcds-nav-link>
  ))}

  {sections.map(section => (
    <gcds-nav-group open-trigger={section.label} menu-label={section.label}>
      {section.links.map(link => (
        <gcds-nav-link href={link.href} aria-current={link.routeKey === routeKey ? "page" : undefined}>
          {link.label}
        </gcds-nav-link>
      ))}
    </gcds-nav-group>
  ))}
</gcds-side-nav>
