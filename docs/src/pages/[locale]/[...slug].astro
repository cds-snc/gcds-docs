---
import { getDocsStaticPaths, type DocsStaticPathProps } from "../../utils/docs-static-paths";
import { getFileModifiedTime } from "../../utils/file-modified";

const pageModules = {
  ...import.meta.glob("../../content-pages/**/*.{astro,mdx}", { eager: true }),
  ...import.meta.glob("../../content-versioned/**/*.{astro,mdx}", { eager: true }),
};

export function getStaticPaths() {
  return getDocsStaticPaths();
}

const { componentPath, label } = Astro.props as DocsStaticPathProps;
const pageModule = pageModules[componentPath] as { default?: unknown; frontmatter?: { lastModified?: string } } | undefined;

if (!pageModule?.default) {
  throw new Error(`Missing page module for route component path: ${componentPath}`);
}

const Page = pageModule.default as any;

// Use git-based lastModified from remark plugin (for MDX) or fall back to file stats (for Astro)
let lastModified = pageModule.frontmatter?.lastModified;
if (!lastModified) {
  lastModified = await getFileModifiedTime(componentPath, "DD MMMM YYYY");
}
---

<Page {...Astro.props} pageTitle={label} lastModified={lastModified} />
